#include <stdio.h>

int main() {
    int a[3][3] = {{1, -2, 3}, {-4, 5, 6}, {7, -8, 9}};
    int maxSum = a[0][0], sum;

    for(int i=0;i<3;i++){
        for(int j=0;j<3;j++){
            sum = a[i][j];
            if(sum > maxSum)
                maxSum = sum;
        }
    }

    printf("Maximum submatrix sum (single element): %d", maxSum);
    return 0;
}
