#include <stdio.h>
struct emp {
    int id;
    char name[20];
};
int main() {
    struct emp e;
    int ch;
    printf("1.Add Employee\n2.Display\n");
    scanf("%d",&ch);
    if(ch==1){
        scanf("%d %s",&e.id,e.name);
    }
    else if(ch==2){
        printf("ID:%d Name:%s", e.id, e.name);
    }
    return 0;
}
