#include <stdio.h>
int main() {
    int a[2][2], flag=1;
    for(int i=0;i<2;i++)
        for(int j=0;j<2;j++)
            scanf("%d",&a[i][j]);
    for(int i=0;i<2;i++)
        for(int j=0;j<2;j++)
            if((i==j && a[i][j]!=1) || (i!=j && a[i][j]!=0))
                flag=0;
    if(flag)
        printf("Identity Matrix");
    else
        printf("Not Identity Matrix");

    return 0;
}
