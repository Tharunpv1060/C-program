#include <stdio.h>
int main() {
    int a[]={1,2,3,4,5};
    int b[]={2,3,5,7};
    int c[]={1,3,4,5};
    int n=5, m=4, k=4;
    for(int i=0;i<n;i++)
        for(int j=0;j<m;j++)
            for(int l=0;l<k;l++)
                if(a[i]==b[j] && b[j]==c[l])
                    printf("%d ", a[i]);
    return 0;
}
