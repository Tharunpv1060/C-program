#include <stdio.h>
int main() {
    int a[3][3], flag=1;
    for(int i=0;i<3;i++)
        for(int j=0;j<3;j++)
            scanf("%d", &a[i][j]);
    for(int i=0;i<3;i++)
        for(int j=0;j<3;j++)
            if(a[i][j] != a[j][i])
                flag=0;
    if(flag)
        printf("Symmetric Matrix");
    else
        printf("Not Symmetric Matrix");
    return 0;
}
