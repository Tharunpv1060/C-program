#include <stdio.h>
#include <string.h>
int main() {
    char str[50], sub[20];
    int count=0;

    gets(str);
    gets(sub);

    for(int i=0;i<=strlen(str)-strlen(sub);i++)
        if(strncmp(&str[i], sub, strlen(sub))==0)
            count++;

    printf("Occurrences: %d", count);
    return 0;
}
