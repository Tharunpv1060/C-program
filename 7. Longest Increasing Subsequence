#include <stdio.h>
int main() {
    int a[]={10,22,9,33}, n=4;
    int lis[4], max=0;

    for(int i=0;i<n;i++) lis[i]=1;

    for(int i=1;i<n;i++)
        for(int j=0;j<i;j++)
            if(a[i]>a[j] && lis[i]<lis[j]+1)
                lis[i]=lis[j]+1;

    for(int i=0;i<n;i++)
        if(lis[i]>max) max=lis[i];

    printf("LIS length: %d", max);
    return 0;
}
