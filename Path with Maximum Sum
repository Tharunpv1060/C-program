#include <stdio.h>

int main() {
    int a[3][3]={{1,2,3},{4,5,6},{7,8,9}};
    int dp[3][3];

    dp[0][0]=a[0][0];

    for(int i=1;i<3;i++){
        dp[i][0]=dp[i-1][0]+a[i][0];
        dp[0][i]=dp[0][i-1]+a[0][i];
    }

    for(int i=1;i<3;i++)
        for(int j=1;j<3;j++)
            dp[i][j]=(dp[i-1][j]>dp[i][j-1]?dp[i-1][j]:dp[i][j-1])+a[i][j];

    printf("Maximum path sum: %d", dp[2][2]);
    return 0;
}
